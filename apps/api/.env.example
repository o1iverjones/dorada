# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://pulpito:password@localhost:5432/pulpito_dev"

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"
REDIS_HOST="localhost"
REDIS_PORT="6379"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Must be at least 32 characters — use `openssl rand -hex 32` to generate
JWT_SECRET="change-me-to-a-random-32-char-secret-in-production"
JWT_ACCESS_TTL="2h"
JWT_REFRESH_TTL_DAYS="30"
ADMIN_REFRESH_TTL_HOURS="720"
MFA_TOKEN_TTL="5m"

# ─── Twilio (SMS OTP + SMS notifications) ─────────────────────────────────────
# Required for interpreter login and SMS follow-up prompts
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# ─── SendGrid (transactional email) ───────────────────────────────────────────
# Required for admin password reset and email confirmations
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL=""
SENDGRID_FROM_NAME="Pulpito"

# ─── Firebase / FCM (push notifications) ──────────────────────────────────────
# Paste the full JSON content of your Firebase service account key
FIREBASE_SERVICE_ACCOUNT_JSON=""

# ─── Google Cloud Storage ─────────────────────────────────────────────────────
# Set GOOGLE_APPLICATION_CREDENTIALS to a service account key file path,
# or rely on Application Default Credentials in GCP environments
GCS_BUCKET="pulpito-media"
GCP_PROJECT_ID=""
GOOGLE_APPLICATION_CREDENTIALS=""

# ─── Anthropic (email intake AI extraction) ───────────────────────────────────
ANTHROPIC_API_KEY=""
CLAUDE_MODEL="claude-sonnet-4-6"

# ─── App ──────────────────────────────────────────────────────────────────────
PORT="3100"
NODE_ENV="development"
LOG_LEVEL="info"

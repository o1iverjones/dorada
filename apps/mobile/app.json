{
  "expo": {
    "name": "Pulpito",
    "slug": "pulpito",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.pulpito.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Used to suggest nearby appointments."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.pulpito.app",
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#3b82f6"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Used to suggest nearby appointments."
        }
      ],
      "expo-localization"
    ],
    "scheme": "pulpito",
    "extra": {
      "apiUrl": "http://192.168.100.21:3100/api/v1",
      "router": {},
      "eas": {
        "projectId": "58b4f722-7db0-42da-a52c-539b63dd5184"
      }
    },
    "owner": "prana2026"
  }
}

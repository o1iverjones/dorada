infrastructure/terraform.tfvars

# Generated reports (local dev only)
/reports/

# Local font files
apps/web/public/*.ttf

# Local uploads (dev fallback — never commit real media)
apps/api/uploads/

# Claude Code internals
.claude/

# Local dev scripts and notes
apps/api/src/scripts/
list-of-modules-needed.md

# Database dumps — may contain real data, never commit
# (Prisma migration files in prisma/migrations/ are tracked; only loose .sql dumps are blocked)
*.sql
!apps/api/prisma/migrations/**/migration.sql

# Android generated files
apps/mobile/android/
apps/mobile/.expo/

# Mobile build artifacts
apps/mobile/*.apk
apps/mobile/*.aab
apps/mobile/*.ipa

# EAS credentials (sensitive)
apps/mobile/credentials.json

# Database dumps and backups — may contain real data, never commit
*.dump

# Generated data files from import scripts
scripts/appointments-clean.json

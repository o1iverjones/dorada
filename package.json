{
  "name": "dorada",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "dev:api": "pnpm --filter @dorada/api dev",
    "dev:worker": "pnpm --filter @dorada/api dev:worker",
    "dev:web": "pnpm --filter @dorada/web dev",
    "dev:mobile": "pnpm --filter @dorada/mobile start"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.0"
  }
}
